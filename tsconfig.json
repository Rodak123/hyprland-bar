{
  "compilerOptions": {
    "target": "ESNext",
    "module": "node20",
    "jsx": "react-jsx",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "paths": {
      "*": [
        "./*"
      ]
    },
    "outDir": "dist",
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": false
  }
}